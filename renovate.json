{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:githubActionsVersions"
  ],
  "conan": {
    "enabled": true
  },
  "customDatasources": [
    {
      "foo": {
        "defaultRegistryUrlTemplate": "https://raw.githubusercontent.com/opendocument-app/conan-odr-index/refs/heads/main/recipes/{{ packageName }}/config.yml",
        "format": "yaml",
        "transformTemplates": [
          "{ \"releases\": versions.$keys().{ \"version\": $ } }"
        ]
      }
    }
  ]
  "packageRules": [
    {
      "matchDatasources": [
        "conan"
      ],
      "registryUrls": [
        "https://center2.conan.io",
        "https://artifactory.opendocument.app/artifactory/api/conan/conan"
      ]
    },
    {
      "matchDatasources": [
        "conan"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all non major dependencies"
    },
    {
      "matchDatasources": [
        "conan"
      ],
      "matchDepNames": [
        "cmake"
      ],
      "allowedVersions": "!/4\\..*/"
    }
  ]
}
