{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:githubActionsVersions"
  ],
  "conan": {
    "enabled": true
  },
  "customDatasources": {
    "conan": {
      "defaultRegistryUrlTemplate": "https://opendocument-app.github.io/conan-odr-index/packages/{{packageName}}.json",
      "format": "json"
    }
  },
  "packageRules": [
    {
      "matchDatasources": [
        "conan"
      ],
      "registryUrls": [
        "https://center2.conan.io"
      ]
    },
    {
      "matchDatasources": [
        "conan"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all non major dependencies"
    },
    {
      "matchDatasources": [
        "conan"
      ],
      "matchDepNames": [
        "cmake"
      ],
      "allowedVersions": "!/4\..*/"
    }
  ]
}
