{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:githubActionsVersions"
  ],
  "conan": {
    "enabled": true
  },
  "customDatasources": {
    "conan-custom": {
      "defaultRegistryUrlTemplate": "https://opendocument-app.github.io/conan-odr-index/packages/{{packageName}}.json",
      "format": "json"
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/conanfile.txt/",
        "/conanfile.py/",
        "/conan.lock/"
      ],
      "matchStrings": [
        "(?<depName>)/(?<currentValue>[^#\\s]+)#(?<currentDigest>[a-f0-9]+)"
      ],
      "datasourceTemplate": "conan-custom"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "conan"
      ],
      "registryUrls": [
        "https://center2.conan.io"
      ]
    },
    {
      "matchDatasources": [
        "conan"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all non major dependencies"
    },
    {
      "matchDatasources": [
        "conan"
      ],
      "matchDepNames": [
        "cmake"
      ],
      "allowedVersions": "!/4\..*/"
    }
  ]
}
