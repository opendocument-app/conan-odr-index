{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:githubActionsVersions"
  ],
  "conan": {
    "enabled": true
  },
  "postUpgradeTasks": {
    "commands": [
      "git clone git@github.com:opendocument-app/conan-odr-index.git",
      "python conan-odr-index/scripts/conan_export_all_packages.py"
    ],
    "fileFilters": ["**/*"]
  },
  "customDatasources": {
    "myConan": {
      "defaultRegistryUrlTemplate": "https://opendocument-app.github.io/conan-odr-index/{{packageName}}.json",
      "format": "json"
    }
  },
  "packageRules": [
    {
      "matchDatasources": [
        "conan"
      ],
      "registryUrls": [
        "https://center2.conan.io"
      ]
    },
    {
      "matchDatasources": [
        "conan"
      ],
      "matchPackageNames": [
        "argon2",
        "cairo",
        "fontconfig",
        "fontforge",
        "glib",
        "libgsf",
        "odrcore",
        "openlibm",
        "pdf2htmlex",
        "poppler",
        "poppler-data",
        "wvware"
      ],
      "overrideDatasource": "myConan",
      "versioning": "conan"
    },
    {
      "matchDatasources": [
        "conan",
        "myConan"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all non major dependencies"
    },
    {
      "matchDatasources": [
        "conan",
        "myConan"
      ],
      "matchDepNames": [
        "cmake"
      ],
      "allowedVersions": "!/4\\..*/"
    }
  ]
}
