{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:githubActionsVersions"
  ],
  "conan": {
    "enabled": true
  },
  "customDatasources": {
    "conan-custom": {
      "defaultRegistryUrlTemplate": "https://opendocument-app.github.io/conan-odr-index/package_index.json",
      "format": "json",
      "transform": "$map($keys($), function($pkg){$map($keys($[$pkg]), function($v){{\"version\":$v,\"digest\":$[$pkg][$v].latest}})})~>$flatten()~>{\"releases\":$}"
    }
  },
  "customManagers": [
    {
      "fileMatch": ["conanfile.txt", "conanfile.py", "conan.lock"],
      "matchStrings": [
        "(?<depName>)/(?<currentValue>[^#\\s]+)#(?<currentDigest>[a-f0-9]+)"
      ],
      "datasourceTemplate": "conan-custom"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "conan"
      ],
      "registryUrls": [
        "https://center2.conan.io"
      ]
    },
    {
      "matchDatasources": [
        "conan"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all non major dependencies"
    },
    {
      "matchDatasources": [
        "conan"
      ],
      "matchDepNames": [
        "cmake"
      ],
      "allowedVersions": "!/4\\..*/"
    }
  ]
}
