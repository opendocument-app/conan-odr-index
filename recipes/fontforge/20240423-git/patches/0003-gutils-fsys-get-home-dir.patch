From: Andreas Stefl <stefl.andreas@gmail.com>
Date: Sun, 31 May 2026 18:27:01 +0200
Subject: [PATCH 3/6] gutils fsys get home dir

---
 gutils/fsys.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/gutils/fsys.c b/gutils/fsys.c
index 19027b0a6..69fd2bd0a 100644
--- a/gutils/fsys.c
+++ b/gutils/fsys.c
@@ -157,6 +157,11 @@ char *GFileGetHomeDir(void) {
 return buffer;
     }
 return NULL;
+#elif defined(__ANDROID__)
+    static char *dir;
+    dir = getenv("HOME");
+    if ( dir!=NULL )
+	return( copy(dir) );
 #else
     static char *dir;
     uid_t uid;
@@ -791,6 +796,9 @@ const char *getUserHomeDir(void) {
 return dir;
 	}
 return NULL;
+#elif defined(__ANDROID__)
+	char *home = getenv("HOME");
+  return home;
 #else
 	uid_t uid;
 	struct passwd *pw;
