From 7d54bcf94fe3b6ad9728f0e0a69297e36899cf52 Mon Sep 17 00:00:00 2001
From: Andreas Stefl <stefl.andreas@gmail.com>
Date: Sun, 31 May 2026 18:42:34 +0200
Subject: [PATCH 3/3] android CheckFileOffsetBits

---
 cmake/modules/CheckFileOffsetBits.cmake | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/cmake/modules/CheckFileOffsetBits.cmake b/cmake/modules/CheckFileOffsetBits.cmake
index b347c936..c8248da0 100644
--- a/cmake/modules/CheckFileOffsetBits.cmake
+++ b/cmake/modules/CheckFileOffsetBits.cmake
@@ -18,6 +18,11 @@ GET_FILENAME_COMPONENT(_selfdir_CheckFileOffsetBits
 	 "${CMAKE_CURRENT_LIST_FILE}" PATH)
 
 MACRO (CHECK_FILE_OFFSET_BITS)
+  IF(ANDROID AND ANDROID_NATIVE_API_LEVEL STRLESS "24")
+    SET(_FILE_OFFSET_BITS "" CACHE INTERNAL "_FILE_OFFSET_BITS macro needed for large files")
+    MESSAGE(STATUS "Not enabling _FILE_OFFSET_BITS for Android API pre 24. This only affects 32bit devices")
+  ENDIF(ANDROID AND ANDROID_NATIVE_API_LEVEL STRLESS "24")
+
   IF(NOT DEFINED _FILE_OFFSET_BITS)
     MESSAGE(STATUS "Checking _FILE_OFFSET_BITS for large files")
     TRY_COMPILE(__WITHOUT_FILE_OFFSET_BITS_64
